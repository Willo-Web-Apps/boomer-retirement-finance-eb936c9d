---
---
<header class="sticky top-0 z-50 border-b border-surface-200/80 bg-surface-50/90 backdrop-blur-lg">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group flex-shrink-0">
      <!-- Nest egg icon -->
      <span class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: oklch(0.39 0.11 155);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="M12 2C6.5 2 2 6 2 11c0 3.9 2.5 7.3 6 8.8V21h8v-1.2c3.5-1.5 6-4.9 6-8.8 0-5-4.5-9-10-9z"/>
          <path d="M9 21v1h6v-1"/>
        </svg>
      </span>
      <span class="text-lg font-bold tracking-tight text-surface-900 font-display group-hover:text-brand-600 transition-colors">NestEgg Guide</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#topics" class="text-sm font-medium text-surface-800/65 hover:text-surface-900 transition-colors">Topics</a>
      <a href="#how-it-works" class="text-sm font-medium text-surface-800/65 hover:text-surface-900 transition-colors">How It Works</a>
      <a href="/blog" class="text-sm font-medium text-surface-800/65 hover:text-surface-900 transition-colors">Guides</a>
    </div>

    <!-- CTA -->
    <a
      href="#get-started"
      class="text-sm font-semibold text-white px-5 py-2.5 rounded-lg transition-colors duration-150 flex-shrink-0"
      style="background: oklch(0.67 0.16 65);"
      onmouseover="this.style.background='oklch(0.57 0.16 65)'"
      onmouseout="this.style.background='oklch(0.67 0.16 65)'"
    >
      Free checklist
    </a>

  </nav>
</header>
