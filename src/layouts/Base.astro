---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "NestEgg Guide — Retire with confidence, not confusion",
  description = "Plain-language retirement guidance for baby boomers within 1–10 years of retirement. Social Security timing, Medicare enrollment, 401(k) withdrawals, and tax planning — in language you can actually use."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "NestEgg Guide",
      "description": "Plain-language retirement planning guidance for baby boomers within 1–10 years of retirement.",
      "url": "https://boomer-retirement-finance.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
